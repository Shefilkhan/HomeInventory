    FIRST VERSION : 2026-04-11
    DESCRIPTION   :
      This is the public-facing landing page of the Home Inventory System.
      Authenticated users are shown a link to their inventory dashboard.
      Unauthenticated visitors are prompted to register or log in.
-->
@{
    ViewData["Title"] = "Welcome";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-9 text-center">
        <h1 class="display-4 fw-extrabold mb-3">
            &#127968; <span class="gradient-text">Home Inventory System</span>
        </h1>
        <p class="lead text-muted mt-3 px-md-5">
            A secure and premium solution to catalogue, value, and track your home assets. 
            Maintain digital records of purchase dates, values, categories, and room locations—fully organized and ready for insurance purposes.
        </p>
        <div class="mt-4 mb-5">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="glass-card d-inline-block p-4 mx-auto mb-4">
                    <p class="fs-5 mb-3">
                        Welcome back, <strong class="gradient-text">@User.Identity.Name</strong>! Ready to manage your items?
                    </p>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a asp-controller="InventoryItems" asp-action="Index"
                           class="btn btn-primary-gradient px-4 py-2 shadow">
                            View My Inventory
                        </a>
                        <a asp-controller="InventoryItems" asp-action="Create"
                           class="btn btn-success-gradient px-4 py-2 shadow">
                            + Add New Item
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                    <a asp-controller="Account" asp-action="Register"
                       class="btn btn-primary-gradient px-4 py-2.5 shadow fs-5">
                        Get Started Free
                    </a>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-outline-glass px-4 py-2.5 fs-5">
                        Log In
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-md-11">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="hover-card text-center">
                    <div class="card-icon">&#128230;</div>
                    <h3 class="card-title">Track Assets</h3>
                    <p class="text-secondary mb-0">
                        Record item details including category, location, purchase date, cost, and serial numbers. Maintain an audit-ready digital logbook.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hover-card text-center">
                    <div class="card-icon">&#128274;</div>
                    <h3 class="card-title">Strict Privacy</h3>
                    <p class="text-secondary mb-0">
                        Rest easy knowing your inventory data is strictly isolated. Only you can view or edit your items after signing in securely.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hover-card text-center">
                    <div class="card-icon">&#128200;</div>
                    <h3 class="card-title">Insurance Ready</h3>
                    <p class="text-secondary mb-0">
                        Generate full valuations of your items at a single glance. Have a quick summary ready whenever you need to make claims.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
