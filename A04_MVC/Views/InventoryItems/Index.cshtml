    FIRST VERSION : 2026-04-12
    DESCRIPTION   :
      This view displays the authenticated user's complete inventory as a
      Bootstrap-styled table. Each row shows the item's name, category, room,
      purchase price, purchase date, and serial number, with action links to
      view Details, Edit, or Delete each item. A total estimated value is
      calculated from all items with a purchase price and displayed at the top.
-->
@model IEnumerable<InventoryItem>
@{
    ViewData["Title"] = "My Inventory";
    decimal totalValue = Model.Where(i => i.PurchasePrice.HasValue)
                              .Sum(i => i.PurchasePrice!.Value);
    int itemCount = Model.Count();
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2><span class="gradient-text">My Inventory</span></h2>
    <a asp-action="Create" class="btn btn-success-gradient shadow">+ Add New Item</a>
</div>

@* Summary bar *@
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-4">
        <div class="dashboard-stat-card stat-primary shadow-sm">
            <h6 class="text-secondary text-uppercase mb-2 font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.05em;">Total Items</h6>
            <p class="display-5 mb-0 fw-extrabold text-white">@itemCount</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="dashboard-stat-card stat-success shadow-sm">
            <h6 class="text-secondary text-uppercase mb-2 font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.05em;">Estimated Total Value</h6>
            <p class="display-5 mb-0 fw-extrabold text-white">@totalValue.ToString("C")</p>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info py-4 text-center glass-card shadow-sm border-0 mt-4">
        <h4 class="alert-heading mb-3">&#9888; No Items Tracked</h4>
        <p class="mb-3 text-secondary">You haven't added any items to your home inventory yet. Let's record your first item!</p>
        <a asp-action="Create" class="btn btn-primary-gradient px-4 py-2 mt-2 shadow">Add Your First Item</a>
    </div>
}
else
{
    <div class="table-responsive shadow-lg">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Category</th>
                    <th>Room / Location</th>
                    <th>Purchase Price</th>
                    <th>Purchase Date</th>
                    <th>Serial Number</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (InventoryItem item in Model)
                {
                    <tr>
                        <td class="fw-semibold text-white">@item.Name</td>
                        <td><span class="badge bg-secondary py-1.5 px-2.5 rounded text-white" style="font-weight: 500;">@item.Category</span></td>
                        <td>@item.Room</td>
                        <td class="fw-semibold text-info">
                            @(item.PurchasePrice.HasValue
                                ? item.PurchasePrice.Value.ToString("C")
                                : "—")
                        </td>
                        <td>
                            @(item.PurchaseDate.HasValue
                                ? item.PurchaseDate.Value.ToString("yyyy-MM-dd")
                                : "—")
                        </td>
                        <td class="text-secondary">@(string.IsNullOrWhiteSpace(item.SerialNumber) ? "—" : item.SerialNumber)</td>
                        <td class="text-center text-nowrap">
                            <a asp-action="Details" asp-route-id="@item.ItemId"
                               class="btn btn-sm btn-outline-glass me-1">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.ItemId"
                               class="btn btn-sm btn-outline-glass me-1" style="color: var(--color-warning); border-color: rgba(245, 158, 11, 0.3);">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.ItemId"
                               class="btn btn-sm btn-outline-glass-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
