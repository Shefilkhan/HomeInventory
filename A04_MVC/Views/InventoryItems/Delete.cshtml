    DESCRIPTION   :
      This view displays a confirmation page before permanently deleting an
      inventory item. It shows the key item details so the user can verify they
      are deleting the correct record. The confirmation form posts to the
      InventoryItemsController.DeleteConfirmed (POST) action. An AntiForgeryToken
      is included to protect against CSRF attacks.
-->
@model InventoryItem
@{
    ViewData["Title"] = "Delete Item";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="glass-card shadow-lg">
            <h2 class="text-danger mb-3">Delete Item</h2>
            <p class="text-secondary mb-4">Confirm permanent deletion of this asset</p>

            <div class="alert alert-warning mb-4" role="alert">
                <strong><i class="bi bi-exclamation-triangle-fill me-1" aria-hidden="true"></i> Warning:</strong> This action is permanent and cannot be undone.
                Are you sure you want to delete the following item?
            </div>

            <dl class="row details-dl mb-4" aria-label="Item delete verification specifications">
                <dt class="col-sm-4"><i class="bi bi-tag-fill text-secondary me-2" aria-hidden="true"></i>Item Name</dt>
                <dd class="col-sm-8 text-white fw-semibold">@Model.Name</dd>

                <dt class="col-sm-4"><i class="bi bi-folder-fill text-secondary me-2" aria-hidden="true"></i>Category</dt>
                <dd class="col-sm-8"><span class="badge bg-secondary py-1.5 px-2.5 rounded text-white" style="font-weight: 500;"><i class="bi bi-tag-fill me-1" aria-hidden="true"></i>@Model.Category</span></dd>

                <dt class="col-sm-4"><i class="bi bi-geo-alt-fill text-secondary me-2" aria-hidden="true"></i>Room / Location</dt>
                <dd class="col-sm-8">@Model.Room</dd>

                <dt class="col-sm-4"><i class="bi bi-currency-dollar text-secondary me-2" aria-hidden="true"></i>Purchase Price</dt>
                <dd class="col-sm-8 text-info fw-semibold">
                    @(Model.PurchasePrice.HasValue
                        ? Model.PurchasePrice.Value.ToString("C")
                        : "—")
                </dd>

                <dt class="col-sm-4"><i class="bi bi-hash text-secondary me-2" aria-hidden="true"></i>Serial Number</dt>
                <dd class="col-sm-8 text-secondary">
                    @(string.IsNullOrWhiteSpace(Model.SerialNumber) ? "—" : Model.SerialNumber)
                </dd>
            </dl>

            <form asp-action="Delete" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ItemId" />
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-danger-gradient shadow px-4">
                        <i class="bi bi-trash me-1" aria-hidden="true"></i>Yes, Delete This Item
                    </button>
                    <a asp-action="Index" class="btn btn-outline-glass px-4"><i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
