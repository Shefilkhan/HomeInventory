      posts to the InventoryItemsController.Create (POST) action.
<!--
    FILE          : Create.cshtml (InventoryItems)
    PROJECT       : PROG2126 - Assignment 04 - Home Inventory System
    PROGRAMMER    : Shefilkhan Fizokhan, Shreyans Kalpesh, Chase McCash
    FIRST VERSION : 2026-04-12
    DESCRIPTION   :
      This view renders the form for creating a new inventory item. It is
      strongly typed to InventoryItem. Category and Room fields are rendered
      as dropdowns populated from ViewBag.CategoryList and ViewBag.RoomList,
      which are set by InventoryItemsController.PopulateDropdowns. The form
      posts to the InventoryItemsController.Create (POST) action.
-->
@model InventoryItem
@{
    ViewData["Title"] = "Add New Item";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="glass-card shadow-lg">
            <h2 class="mb-3"><span class="gradient-text">Add New Item</span></h2>
            <p class="text-secondary mb-4">Catalogue a new asset in your home inventory</p>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"
                 style="display: @(ViewData.ModelState.IsValid ? "none" : "block")">
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text" id="name-lbl-icon"><i class="bi bi-tag" aria-hidden="true"></i></span>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Living Room Smart TV" aria-describedby="name-lbl-icon" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter optional item description, condition, details, etc."></textarea>
                    <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="Category" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text" id="category-lbl-icon"><i class="bi bi-folder2" aria-hidden="true"></i></span>
                            <select asp-for="Category" asp-items="ViewBag.CategoryList"
                                    class="form-select" aria-describedby="category-lbl-icon">
                                <option value="">-- Select a Category --</option>
                            </select>
                        </div>
                        <span asp-validation-for="Category" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Room" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text" id="room-lbl-icon"><i class="bi bi-geo-alt" aria-hidden="true"></i></span>
                            <select asp-for="Room" asp-items="ViewBag.RoomList"
                                    class="form-select" aria-describedby="room-lbl-icon">
                                <option value="">-- Select a Room --</option>
                            </select>
                        </div>
                        <span asp-validation-for="Room" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="PurchaseDate" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text" id="date-lbl-icon"><i class="bi bi-calendar3" aria-hidden="true"></i></span>
                            <input asp-for="PurchaseDate" type="text" class="form-control datepicker" placeholder="Select Date (YYYY-MM-DD)" aria-describedby="date-lbl-icon" />
                        </div>
                        <span asp-validation-for="PurchaseDate" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="PurchasePrice" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text" id="price-lbl-icon"><i class="bi bi-currency-dollar" aria-hidden="true"></i></span>
                            <input asp-for="PurchasePrice" type="number" step="0.01" min="0"
                                   class="form-control" placeholder="0.00" aria-describedby="price-lbl-icon" />
                        </div>
                        <span asp-validation-for="PurchasePrice" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="SerialNumber" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text" id="serial-lbl-icon"><i class="bi bi-hash" aria-hidden="true"></i></span>
                        <input asp-for="SerialNumber" class="form-control" placeholder="e.g. SN1234567890" aria-describedby="serial-lbl-icon" />
                    </div>
                    <span asp-validation-for="SerialNumber" class="text-danger small mt-1 d-block"></span>
                    <div class="form-text text-secondary mt-1">Optional. Enter the manufacturer serial number.</div>
                </div>

                <div class="d-flex gap-3 mt-4 pt-2">
                    <button type="submit" class="btn btn-success-gradient shadow px-4">Save Item</button>
                    <a asp-action="Index" class="btn btn-outline-glass px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
