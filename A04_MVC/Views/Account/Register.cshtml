    DESCRIPTION   :
      This view renders the user registration form for the Home Inventory
      System. It is strongly typed to RegisterViewModel. Validation annotations
      (Required, StringLength, Compare) are enforced both client-side via jQuery
      Validation and server-side in the AccountController.Register (POST) action.
-->
@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="glass-card shadow-lg">
            <h2 class="text-center mb-4"><span class="gradient-text">Register</span></h2>
            <p class="text-center text-secondary mb-4">Create your secure Home Inventory account</p>

            <div asp-validation-summary="All" class="alert alert-danger mb-4" role="alert"
                 style="display: @(ViewData.ModelState.IsValid ? "none" : "block")">
            </div>

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="Username" class="form-label fw-semibold"></label>
                    <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Choose a username" />
                    <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
                    <div class="form-text text-secondary mt-1">Max 50 characters.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" type="password"
                           autocomplete="new-password" placeholder="Create a secure password" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    <div class="form-text text-secondary mt-1">Minimum 6 characters.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password"
                           autocomplete="new-password" placeholder="Confirm your password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-success-gradient w-100 mt-2 shadow py-2.5">Create Account</button>
            </form>

            <p class="mt-4 mb-0 text-center text-secondary">
                Already have an account? 
                <a asp-controller="Account" asp-action="Login" class="gradient-text text-decoration-none fw-semibold">Login here</a>
            </p>
        </div>
    </div>
</div>
