    DESCRIPTION   :
      This view renders the user registration form for the Home Inventory
      System. It is strongly typed to RegisterViewModel. Validation annotations
      (Required, StringLength, Compare) are enforced both client-side via jQuery
      Validation and server-side in the AccountController.Register (POST) action.
-->
@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-5">
        <h2>Create an Account</h2>
        <hr />

        <div asp-validation-summary="All" class="alert alert-danger" role="alert"
             style="display: @(ViewData.ModelState.IsValid ? "none" : "block")">
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Username" class="form-label fw-semibold"></label>
                <input asp-for="Username" class="form-control" autocomplete="username" />
                <span asp-validation-for="Username" class="text-danger small"></span>
                <div class="form-text">Max 50 characters.</div>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control"
                       autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div class="form-text">Minimum 6 characters.</div>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                <input asp-for="ConfirmPassword" class="form-control"
                       autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success w-100">Create Account</button>
        </form>

        <p class="mt-3 text-center">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Login here</a>
        </p>
    </div>
</div>
