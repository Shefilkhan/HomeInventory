    DESCRIPTION   :
      This view renders the Login form for the Home Inventory System. It is
      strongly typed to LoginViewModel and uses ASP.NET Core Tag Helpers for
      two-way model binding and client-side validation. Server-side validation
      errors are displayed via asp-validation-summary. The form posts to the
      AccountController.Login (POST) action.
-->
@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="glass-card shadow-lg">
            <h2 class="text-center mb-4"><span class="gradient-text">Log In</span></h2>
            <p class="text-center text-secondary mb-4">Access your Home Inventory Dashboard</p>

            <div asp-validation-summary="All" class="alert alert-danger mb-4" role="alert"
                 style="display: @(ViewData.ModelState.IsValid ? "none" : "block")">
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl"
                       value="@(ViewData["ReturnUrl"]?.ToString() ?? string.Empty)" />

                <div class="mb-4">
                    <label asp-for="Username" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text" id="username-icon"><i class="bi bi-person-fill" aria-hidden="true"></i></span>
                        <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Enter username" aria-describedby="username-icon" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text" id="password-icon"><i class="bi bi-lock-fill" aria-hidden="true"></i></span>
                        <input asp-for="Password" class="form-control" type="password"
                               autocomplete="current-password" placeholder="Enter password" aria-describedby="password-icon" />
                        <button class="btn btn-outline-glass password-toggle-btn px-3" type="button" aria-label="Show password">
                            <i class="bi bi-eye" aria-hidden="true"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-primary-gradient w-100 mt-2 shadow py-2.5">Login</button>
            </form>

            <p class="mt-4 mb-0 text-center text-secondary">
                Don't have an account? 
                <a asp-controller="Account" asp-action="Register" class="gradient-text text-decoration-none fw-semibold">Register here</a>
            </p>
        </div>
    </div>
</div>
