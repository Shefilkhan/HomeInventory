<!DOCTYPE html>
<!--
    FILE          : _Layout.cshtml
    PROJECT       : PROG2126 - Assignment 04 - Home Inventory System
    PROGRAMMER    : Shefilkhan Fizokhan, Chase McCash, Shreyans Kalpesh
    FIRST VERSION : 2026-04-12
    DESCRIPTION   :
      This file is the shared Razor layout template for the Home Inventory
      System. It defines the common HTML document structure, navigation bar,
      main content region, and footer rendered across every page of the
      application. Bootstrap 5 is loaded via CDN for styling. The navigation
      bar dynamically shows Login / Register for guests and My Inventory /
      Add Item / Logout for authenticated users using User.Identity.
-->
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Home Inventory System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-glass mb-4 shadow">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    &#127968; Home Inventory
                </a>
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @* Show inventory links only to authenticated users *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="InventoryItems" asp-action="Index">
                                    My Inventory
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link me-2"
                                   asp-controller="InventoryItems" asp-action="Create">
                                    + Add Item
                                </a>
                            </li>
                            <li class="nav-item">
                                <span class="nav-link text-light fst-italic pe-3">
                                    Hello, @User.Identity.Name!
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-glass my-1">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mt-4">
        <div class="container">
            <span class="text-secondary">&copy; 2026 &mdash; Home Inventory System &mdash; PROG2126 Assignment 04</span>
            <span class="float-end">
                <a asp-controller="Home" asp-action="Privacy" class="text-secondary text-decoration-none hover-white">Privacy Policy</a>
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
